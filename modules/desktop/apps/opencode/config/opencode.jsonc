{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "https://litellm.tiebe.me/v1"
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://api.apipro.me/v1"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "limit": {
            "context": 256000,
            "output": 128000
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini"
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex"
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash"
        },
        "glm-5.1": {
          "name": "GLM 5.1"
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6"
        },
        "minimax-m2.7": {
          "name": "Minimax M2.7"
        }
      }
    }
  },
  "agent": {
    "direct": {
      "description": "Direct OpenCode agent without plugin orchestration",
      "mode": "primary",
      "model": "litellm/gpt-5.4-mini"
    }
  },
  "model": "litellm/gpt-5.5",
  "small_model": "litellm/gpt-5.4-mini"
}
