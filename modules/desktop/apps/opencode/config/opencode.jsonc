{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest",
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "https://litellm.tiebe.me/v1"
      },
      "models": {
        "claude-opus-4.6": {
          "options": {
            "maxContextWindow": 200000
          }
        },
        "claude-sonnet-4.6": {
          "options": {
            "maxContextWindow": 200000
          }
        }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://127.0.0.1:4001/v1"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "limit": {
            "context": 256000,
            "output": 128000
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini"
        },
        "minimax-m2.7": {
          "name": "Minimax M2.7"
        }
      }
    }
  },
  "agent": {
    "direct": {
      "description": "Direct OpenCode agent without plugin orchestration",
      "mode": "primary",
      "model": "litellm/gpt-5.4-mini"
    }
  },
  "model": "litellm/gpt-5.5",
  "small_model": "litellm/gpt-5.4-mini"
}