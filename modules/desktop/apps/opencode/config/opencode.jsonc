{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest",
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest",
    "opencode-gemini-auth@latest"
  ],
  "provider": {
    "zai-coding-plan": {
      "models": {
        "glm-5": {
          "options": {
            "maxContextWindow": 100000
          }
        }
      }
    }
  },
  "mcp": {
    "firefox-devtools": {
      "type": "local",
      "command": ["npx", "-y", "firefox-devtools-mcp@latest", "--viewport", "1280x720"],
      "environment": {
        "START_URL": "about:home"
      },
      "enabled": true
    }
  }
}
