{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-cbcea3be-3589-4fd8-9f94-aaace0c7decb"
      },
      "enabled": true
    }
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://litellm.tiebe.me/v1"
      },
      "models": {
       "claude-opus-4.8": {
          "name": "Claude Opus 4.8",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "gemini-3.5-flash-low": {
          "name": "Gemini 3.5 Flash (Low)"
        },
        "gpt-5.5": {
          "name": "GPT-5.5"
        },
        "nemotron-3-ultra": {
          "name": "Nemotron 3 Ultra"
        }
      }
    }
  },
  "model": "litellm/claude-opus-4.8",
  "small_model": "litellm/gemini-3.5-flash-low"
}
