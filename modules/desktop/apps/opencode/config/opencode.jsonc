{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest",
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest",
    "opencode-gemini-auth@latest"
  ],
  "provider": {
    "zai-coding-plan": {
      "models": {
        "glm-5": {
          "options": {
            "maxContextWindow": 100000
          }
        }
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "https://api.apipro.me/v1"
      },
      "models": {
        "claude-opus-4.6": {
          "options": {
            "maxContextWindow": 200000
          }
        },
        "claude-sonnet-4.6": {
          "options": {
            "maxContextWindow": 200000
          }
        }
      }
    },
    "apipro-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "APIPro OpenAI",
      "options": {
        "baseURL": "https://api.apipro.me/v1"
      },
      "models": {
        "gpt-5": {
          "name": "GPT-5"
        },
        "gpt-5-codex": {
          "name": "GPT-5 Codex"
        },
        "gpt-5-codex-mini": {
          "name": "GPT-5 Codex Mini"
        },
        "gpt-5.1": {
          "name": "GPT-5.1"
        },
        "gpt-5.1-codex": {
          "name": "GPT-5.1 Codex"
        },
        "gpt-5.1-codex-max": {
          "name": "GPT-5.1 Codex Max"
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini"
        },
        "gpt-5.2": {
          "name": "GPT-5.2"
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex"
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex"
        },
        "gpt-5.4": {
          "name": "GPT-5.4"
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini"
        }
      }
    }
  },
  "mcp": {
    "firefox-devtools": {
      "type": "local",
      "command": ["npx", "-y", "firefox-devtools-mcp@latest", "--viewport", "1280x720"],
      "environment": {
        "START_URL": "about:home"
      },
      "enabled": true
    }
  }
}
